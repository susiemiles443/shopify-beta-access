<section id="beta-access-application-{{ section.id }}" class="beta-access beta-access--{{ section.id }}">
  <div class="beta-access__noise"></div>
  <div class="beta-access__container">
    <div class="beta-access__shell">
      <div class="beta-access__panel beta-access__panel--form" id="beta-panel-form-{{ section.id }}">
        <div class="beta-access__header">
          <div class="beta-access__badge">
            <span class="beta-access__badge-dot"></span>
            <span>BETA ACCESS</span>
          </div>

          <h2 class="beta-access__title">{{ section.settings.heading }}</h2>

          <div class="beta-access__description rte">
            {{ section.settings.description }}
          </div>
        </div>

        {% if customer %}
          <div class="beta-access__form">
            <div class="beta-access__field" id="beta-field-{{ section.id }}">
              <label for="beta-email-{{ section.id }}" class="beta-access__label">
                Registered Email
              </label>

              <div class="beta-access__input-wrap">
                <span class="beta-access__input-icon">
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M4 6.75A2.75 2.75 0 0 1 6.75 4h10.5A2.75 2.75 0 0 1 20 6.75v10.5A2.75 2.75 0 0 1 17.25 20H6.75A2.75 2.75 0 0 1 4 17.25V6.75Zm2.32.2a.75.75 0 0 0-.07 1.06l4.87 5.56a1.2 1.2 0 0 0 1.76 0l4.87-5.56a.75.75 0 1 0-1.13-.99l-4.62 5.27-4.62-5.27a.75.75 0 0 0-1.06-.07Z" fill="currentColor"></path>
                  </svg>
                </span>

                <input
                  id="beta-email-{{ section.id }}"
                  class="beta-access__input"
                  type="email"
                  placeholder="Enter your registered email"
                  autocomplete="email"
                >
              </div>

              <div class="beta-access__hint">
                Use the same email address as your logged-in customer account.
              </div>
            </div>

            <div class="beta-access__status-row">
              <div class="beta-access__micro-status" id="beta-micro-status-{{ section.id }}">
                Awaiting verification
              </div>
            </div>

            <div id="beta-agreement-wrap-{{ section.id }}" class="beta-access__agreement" style="display:none;">
              <div class="beta-access__agreement-head">
                <span class="beta-access__agreement-pill">AGREEMENT</span>
              </div>

              <label class="beta-access__checkbox-row" for="beta-agree-{{ section.id }}">
                <input id="beta-agree-{{ section.id }}" class="beta-access__checkbox" type="checkbox">
                <span class="beta-access__checkbox-ui"></span>
                <div class="beta-access__agreement-text rte">
                  {{ section.settings.agreement_text }}
                </div>
              </label>
            </div>

            <div class="beta-access__actions">
              <button id="beta-verify-{{ section.id }}" type="button" class="beta-access__button beta-access__button--ghost">
                <span class="beta-access__button-text">{{ section.settings.verify_button_label }}</span>
              </button>

              <button id="beta-submit-{{ section.id }}" type="button" class="beta-access__button beta-access__button--primary" style="display:none;">
                <span class="beta-access__button-text">{{ section.settings.submit_button_label }}</span>
                <span class="beta-access__spinner" aria-hidden="true"></span>
              </button>
            </div>

            <div id="beta-message-{{ section.id }}" class="beta-access__message" aria-live="polite"></div>
          </div>
        {% else %}
          <div class="beta-access__login">
            <div class="beta-access__login-icon">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M12 2a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 12c4.42 0 8 2.24 8 5v1a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-1c0-2.76 3.58-5 8-5Z" fill="currentColor"></path>
              </svg>
            </div>
            <p>Please log in to your customer account before applying.</p>
          </div>
        {% endif %}
      </div>

      {% if customer %}
        <div class="beta-access__panel beta-access__panel--success" id="beta-panel-success-{{ section.id }}" hidden>
          <div class="beta-access__success-orb"></div>
          <div class="beta-access__success-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9.55 16.6 5.7 12.75a1 1 0 1 0-1.4 1.42l4.56 4.55a1 1 0 0 0 1.4 0l9.45-9.45a1 1 0 1 0-1.41-1.41L9.55 16.6Z" fill="currentColor"></path>
            </svg>
          </div>
          <div class="beta-access__success-badge">APPLICATION RECEIVED</div>
          <h3 class="beta-access__success-title">You’re on the beta list.</h3>
          <p class="beta-access__success-text">
            Your request has been submitted successfully. Our team will review eligibility and follow up if needed.
          </p>
          <button type="button" class="beta-access__button beta-access__button--soft" id="beta-reset-view-{{ section.id }}">
            <span class="beta-access__button-text">Back to form</span>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .beta-access--{{ section.id }} {
    --bg: #f3f5f7;
    --bg-2: #eef1f4;
    --panel: rgba(255, 255, 255, 0.78);
    --panel-strong: rgba(255, 255, 255, 0.92);
    --text: #111827;
    --muted: #667085;
    --line: rgba(17, 24, 39, 0.08);
    --line-strong: rgba(68, 87, 124, 0.16);
    --blue: #3b82f6;
    --blue-2: #7c3aed;
    --blue-soft: rgba(59, 130, 246, 0.10);
    --green: #0f9f6e;
    --green-soft: rgba(15, 159, 110, 0.12);
    --error: #dc2626;
    --error-soft: rgba(220, 38, 38, 0.08);
    --shadow-lg: 0 24px 70px rgba(17, 24, 39, 0.08);
    --shadow-md: 0 12px 30px rgba(17, 24, 39, 0.06);
    --radius-xl: 28px;
    --radius-lg: 20px;
    --radius-md: 16px;
    position: relative;
    overflow: hidden;
    padding: 72px 20px;
    background:
      radial-gradient(circle at 0% 0%, rgba(124, 58, 237, 0.05), transparent 28%),
      radial-gradient(circle at 100% 0%, rgba(59, 130, 246, 0.06), transparent 26%),
      linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
    color: var(--text);
  }

  .beta-access--{{ section.id }} .beta-access__noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.25;
    background-image:
      linear-gradient(rgba(17,24,39,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17,24,39,0.025) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(circle at center, rgba(0,0,0,0.85), transparent 88%);
    -webkit-mask-image: radial-gradient(circle at center, rgba(0,0,0,0.85), transparent 88%);
  }

  .beta-access--{{ section.id }} .beta-access__container {
    position: relative;
    z-index: 1;
    max-width: 980px;
    margin: 0 auto;
  }

  .beta-access--{{ section.id }} .beta-access__shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .beta-access--{{ section.id }} .beta-access__panel {
    position: relative;
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    background: linear-gradient(180deg, var(--panel-strong), var(--panel));
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .beta-access--{{ section.id }} .beta-access__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(59, 130, 246, 0.08), transparent 24%, transparent 72%, rgba(124, 58, 237, 0.06));
  }

  .beta-access--{{ section.id }} .beta-access__panel--form {
    padding: 34px;
  }

  .beta-access--{{ section.id }} .beta-access__header {
    margin-bottom: 28px;
  }

  .beta-access--{{ section.id }} .beta-access__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(59, 130, 246, 0.12);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 6px 18px rgba(59, 130, 246, 0.06);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #3559c7;
  }

  .beta-access--{{ section.id }} .beta-access__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6, #7c3aed);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.10);
  }

  .beta-access--{{ section.id }} .beta-access__title {
    margin: 0 0 12px;
    font-size: clamp(30px, 5vw, 50px);
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #0f172a;
  }

  .beta-access--{{ section.id }} .beta-access__description,
  .beta-access--{{ section.id }} .beta-access__agreement-text,
  .beta-access--{{ section.id }} .beta-access__success-text {
    color: var(--muted);
    line-height: 1.72;
    font-size: 15px;
  }

  .beta-access--{{ section.id }} .beta-access__description p:last-child,
  .beta-access--{{ section.id }} .beta-access__agreement-text p:last-child {
    margin-bottom: 0;
  }

  .beta-access--{{ section.id }} .beta-access__field {
    margin-bottom: 12px;
  }

  .beta-access--{{ section.id }} .beta-access__label {
    display: block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #475467;
  }

  .beta-access--{{ section.id }} .beta-access__input-wrap {
    position: relative;
  }

  .beta-access--{{ section.id }} .beta-access__input-icon {
    position: absolute;
    top: 50%;
    left: 16px;
    width: 18px;
    height: 18px;
    color: #98a2b3;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .beta-access--{{ section.id }} .beta-access__input-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .beta-access--{{ section.id }} .beta-access__input {
    width: 100%;
    min-height: 58px;
    padding: 16px 18px 16px 46px;
    border-radius: 18px;
    border: 1px solid var(--line-strong);
    background: rgba(255, 255, 255, 0.92);
    color: #0f172a;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, transform 0.2s ease;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
  }

  .beta-access--{{ section.id }} .beta-access__input::placeholder {
    color: #98a2b3;
  }

  .beta-access--{{ section.id }} .beta-access__input:hover {
    border-color: rgba(59, 130, 246, 0.28);
  }

  .beta-access--{{ section.id }} .beta-access__input:focus {
    border-color: rgba(59, 130, 246, 0.65);
    box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.10), 0 12px 30px rgba(59, 130, 246, 0.08);
    background: #fff;
    transform: translateY(-1px);
  }

  .beta-access--{{ section.id }} .beta-access__field.is-valid .beta-access__input {
    border-color: rgba(15, 159, 110, 0.42);
    box-shadow: 0 0 0 4px rgba(15, 159, 110, 0.08);
  }

  .beta-access--{{ section.id }} .beta-access__field.is-error .beta-access__input {
    border-color: rgba(220, 38, 38, 0.42);
    box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.08);
  }

  .beta-access--{{ section.id }} .beta-access__hint {
    margin-top: 10px;
    font-size: 13px;
    color: #667085;
  }

  .beta-access--{{ section.id }} .beta-access__status-row {
    margin: 14px 0 6px;
  }

  .beta-access--{{ section.id }} .beta-access__micro-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 32px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(17, 24, 39, 0.04);
    color: #667085;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: all 0.2s ease;
  }

  .beta-access--{{ section.id }} .beta-access__micro-status.is-valid {
    background: var(--green-soft);
    color: var(--green);
  }

  .beta-access--{{ section.id }} .beta-access__micro-status.is-error {
    background: var(--error-soft);
    color: var(--error);
  }

  .beta-access--{{ section.id }} .beta-access__micro-status.is-info {
    background: var(--blue-soft);
    color: var(--blue);
  }

  .beta-access--{{ section.id }} .beta-access__agreement {
    margin: 22px 0 8px;
    padding: 18px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.64);
    box-shadow: var(--shadow-md);
  }

  .beta-access--{{ section.id }} .beta-access__agreement-head {
    margin-bottom: 12px;
  }

  .beta-access--{{ section.id }} .beta-access__agreement-pill {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.08);
    color: #3559c7;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .beta-access--{{ section.id }} .beta-access__checkbox-row {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 14px;
    align-items: start;
    cursor: pointer;
  }

  .beta-access--{{ section.id }} .beta-access__checkbox {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .beta-access--{{ section.id }} .beta-access__checkbox-ui {
    position: relative;
    width: 22px;
    height: 22px;
    margin-top: 2px;
    border-radius: 8px;
    border: 1px solid rgba(71, 84, 103, 0.22);
    background: #fff;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.85);
    transition: all 0.18s ease;
  }

  .beta-access--{{ section.id }} .beta-access__checkbox:checked + .beta-access__checkbox-ui {
    border-color: rgba(59, 130, 246, 0.58);
    background: linear-gradient(135deg, #3b82f6 0%, #7c3aed 100%);
    box-shadow: 0 8px 18px rgba(59, 130, 246, 0.18);
  }

  .beta-access--{{ section.id }} .beta-access__checkbox:checked + .beta-access__checkbox-ui::after {
    content: "";
    position: absolute;
    left: 7px;
    top: 3px;
    width: 5px;
    height: 10px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .beta-access--{{ section.id }} .beta-access__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .beta-access--{{ section.id }} .beta-access__button {
    position: relative;
    appearance: none;
    border: 0;
    cursor: pointer;
    min-height: 52px;
    padding: 14px 20px;
    border-radius: 16px;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease, background 0.18s ease, border-color 0.18s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .beta-access--{{ section.id }} .beta-access__button:hover {
    transform: translateY(-1px);
  }

  .beta-access--{{ section.id }} .beta-access__button:active {
    transform: translateY(0);
  }

  .beta-access--{{ section.id }} .beta-access__button[disabled] {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .beta-access--{{ section.id }} .beta-access__button--ghost {
    color: #0f172a;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
  }

  .beta-access--{{ section.id }} .beta-access__button--ghost:hover {
    border-color: rgba(59, 130, 246, 0.18);
    box-shadow: 0 14px 34px rgba(17, 24, 39, 0.08);
  }

  .beta-access--{{ section.id }} .beta-access__button--primary {
    color: #fff;
    background: linear-gradient(135deg, #3b82f6 0%, #5b7cff 45%, #7c3aed 100%);
    box-shadow: 0 16px 36px rgba(59, 130, 246, 0.22);
  }

  .beta-access--{{ section.id }} .beta-access__button--primary:hover {
    box-shadow: 0 20px 40px rgba(59, 130, 246, 0.28);
  }

  .beta-access--{{ section.id }} .beta-access__button--soft {
    color: #0f172a;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
  }

  .beta-access--{{ section.id }} .beta-access__spinner {
    display: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.35);
    border-top-color: #fff;
    animation: beta-access-spin-{{ section.id }} 0.75s linear infinite;
  }

  .beta-access--{{ section.id }} .beta-access__button.is-loading .beta-access__spinner {
    display: inline-block;
  }

  .beta-access--{{ section.id }} .beta-access__button.is-loading .beta-access__button-text {
    opacity: 0.92;
  }

  @keyframes beta-access-spin-{{ section.id }} {
    to { transform: rotate(360deg); }
  }

  .beta-access--{{ section.id }} .beta-access__message {
    margin-top: 18px;
    min-height: 24px;
    font-size: 14px;
    line-height: 1.6;
  }

  .beta-access--{{ section.id }} .beta-access__message.success {
    color: var(--green);
  }

  .beta-access--{{ section.id }} .beta-access__message.error {
    color: var(--error);
  }

  .beta-access--{{ section.id }} .beta-access__message.info {
    color: var(--blue);
  }

  .beta-access--{{ section.id }} .beta-access__login {
    padding: 22px;
    border-radius: var(--radius-lg);
    background: rgba(255,255,255,0.72);
    border: 1px solid var(--line);
    color: var(--text);
  }

  .beta-access--{{ section.id }} .beta-access__login-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    margin-bottom: 12px;
    border-radius: 14px;
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.08);
  }

  .beta-access--{{ section.id }} .beta-access__login-icon svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  .beta-access--{{ section.id }} .beta-access__panel--success {
    padding: 36px 30px;
    text-align: center;
    background:
      radial-gradient(circle at top center, rgba(59, 130, 246, 0.08), transparent 32%),
      linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.82));
  }

  .beta-access--{{ section.id }} .beta-access__success-orb {
    position: absolute;
    top: -80px;
    left: 50%;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(59,130,246,0.12), transparent 68%);
    pointer-events: none;
  }

  .beta-access--{{ section.id }} .beta-access__success-icon {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    margin: 0 auto 18px;
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    background: linear-gradient(180deg, rgba(15, 159, 110, 0.14), rgba(15, 159, 110, 0.08));
    box-shadow: 0 18px 36px rgba(15, 159, 110, 0.10);
  }

  .beta-access--{{ section.id }} .beta-access__success-icon svg {
    width: 30px;
    height: 30px;
    display: block;
  }

  .beta-access--{{ section.id }} .beta-access__success-badge {
    display: inline-block;
    margin-bottom: 12px;
    padding: 7px 12px;
    border-radius: 999px;
    background: var(--green-soft);
    color: var(--green);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .beta-access--{{ section.id }} .beta-access__success-title {
    margin: 0 0 10px;
    font-size: clamp(24px, 4vw, 34px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #0f172a;
  }

  .beta-access--{{ section.id }} .beta-access__success-text {
    max-width: 560px;
    margin: 0 auto 22px;
  }

  .beta-access--{{ section.id }} a {
    color: #3559c7;
  }

  @media screen and (max-width: 749px) {
    .beta-access--{{ section.id }} {
      padding: 48px 16px;
    }

    .beta-access--{{ section.id }} .beta-access__panel--form,
    .beta-access--{{ section.id }} .beta-access__panel--success {
      padding: 22px;
      border-radius: 22px;
    }

    .beta-access--{{ section.id }} .beta-access__actions {
      flex-direction: column;
    }

    .beta-access--{{ section.id }} .beta-access__button {
      width: 100%;
    }
  }
</style>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const customerId = '{{ customer.id | default: "" }}';
    const customerEmail = '{{ customer.email | default: "" | escape }}';
    const apiUrl = '{{ section.settings.vercel_api_url }}';
    const allowedEmailRulesRaw = {{ section.settings.allowed_email_rules | json }};

    const emailInput = document.getElementById(`beta-email-${sectionId}`);
    const verifyBtn = document.getElementById(`beta-verify-${sectionId}`);
    const submitBtn = document.getElementById(`beta-submit-${sectionId}`);
    const agreementWrap = document.getElementById(`beta-agreement-wrap-${sectionId}`);
    const agreeCheckbox = document.getElementById(`beta-agree-${sectionId}`);
    const messageEl = document.getElementById(`beta-message-${sectionId}`);
    const microStatusEl = document.getElementById(`beta-micro-status-${sectionId}`);
    const fieldEl = document.getElementById(`beta-field-${sectionId}`);
    const formPanelEl = document.getElementById(`beta-panel-form-${sectionId}`);
    const successPanelEl = document.getElementById(`beta-panel-success-${sectionId}`);
    const resetViewBtn = document.getElementById(`beta-reset-view-${sectionId}`);

    if (!emailInput || !verifyBtn || !submitBtn || !agreementWrap || !messageEl) return;

    function setMessage(text, type) {
      messageEl.textContent = text || '';
      messageEl.className = 'beta-access__message' + (type ? ` ${type}` : '');
    }

    function setMicroStatus(text, type) {
      if (!microStatusEl) return;
      microStatusEl.textContent = text || '';
      microStatusEl.className = 'beta-access__micro-status' + (type ? ` is-${type}` : '');
    }

    function setFieldState(type) {
      if (!fieldEl) return;
      fieldEl.classList.remove('is-valid', 'is-error');
      if (type === 'valid') fieldEl.classList.add('is-valid');
      if (type === 'error') fieldEl.classList.add('is-error');
    }

    function normalizeEmail(value) {
      return String(value || '').trim().toLowerCase();
    }

    function parseAllowedRules(raw) {
      return String(raw || '')
        .split(/\r?\n/)
        .map(function(item) { return item.trim().toLowerCase(); })
        .filter(Boolean);
    }

    function isEmailAllowed(email, rules) {
      if (!rules.length) return true;

      return rules.some(function(rule) {
        if (!rule) return false;
        if (rule.indexOf('@') === 0) return email.endsWith(rule);
        return email === rule;
      });
    }

    function hideAgreement() {
      agreementWrap.style.display = 'none';
      submitBtn.style.display = 'none';
      if (agreeCheckbox) agreeCheckbox.checked = false;
    }

    function showAgreement() {
      agreementWrap.style.display = 'block';
      submitBtn.style.display = 'inline-flex';
    }

    function setSubmittingState(isSubmitting) {
      submitBtn.disabled = isSubmitting;
      verifyBtn.disabled = isSubmitting;

      if (isSubmitting) {
        submitBtn.classList.add('is-loading');
      } else {
        submitBtn.classList.remove('is-loading');
      }
    }

    function showSuccessPanel() {
      if (!formPanelEl || !successPanelEl) return;
      formPanelEl.hidden = true;
      successPanelEl.hidden = false;
      successPanelEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function showFormPanel() {
      if (!formPanelEl || !successPanelEl) return;
      formPanelEl.hidden = false;
      successPanelEl.hidden = true;
    }

    const allowedRules = parseAllowedRules(allowedEmailRulesRaw);

    setMicroStatus('Awaiting verification', '');

    emailInput.addEventListener('input', function() {
      setMessage('', '');
      setFieldState('');
      setMicroStatus('Editing email', 'info');
      hideAgreement();
    });

    emailInput.addEventListener('blur', function() {
      const inputEmail = normalizeEmail(emailInput.value);
      if (!inputEmail) {
        setFieldState('');
        setMicroStatus('Awaiting verification', '');
        return;
      }

      if (inputEmail.indexOf('@') > 0) {
        setMicroStatus('Email format looks valid', 'info');
      } else {
        setFieldState('error');
        setMicroStatus('Please enter a valid email', 'error');
      }
    });

    verifyBtn.addEventListener('click', function() {
      const inputEmail = normalizeEmail(emailInput.value);
      const loggedInEmail = normalizeEmail(customerEmail);

      if (!customerId) {
        setFieldState('error');
        setMicroStatus('Login required', 'error');
        setMessage('You must be logged in.', 'error');
        return;
      }

      if (!inputEmail) {
        setFieldState('error');
        setMicroStatus('Missing email', 'error');
        setMessage('Please enter your email.', 'error');
        return;
      }

      if (inputEmail.indexOf('@') < 1) {
        setFieldState('error');
        setMicroStatus('Invalid email format', 'error');
        setMessage('Please enter a valid email address.', 'error');
        return;
      }

      if (inputEmail !== loggedInEmail) {
        setFieldState('error');
        setMicroStatus('Account mismatch', 'error');
        setMessage('The email must match your logged-in customer account email.', 'error');
        hideAgreement();
        return;
      }

      if (!isEmailAllowed(inputEmail, allowedRules)) {
        setFieldState('error');
        setMicroStatus('Not eligible', 'error');
        setMessage('This email is not eligible for beta access.', 'error');
        hideAgreement();
        return;
      }

      setFieldState('valid');
      setMicroStatus('Eligible to apply', 'valid');
      showAgreement();
      setMessage('Email verified. Please review the agreement and submit your request.', 'success');
    });

    submitBtn.addEventListener('click', async function() {
      try {
        const inputEmail = normalizeEmail(emailInput.value);
        const agreed = !!agreeCheckbox.checked;
        const loggedInEmail = normalizeEmail(customerEmail);

        if (!inputEmail) {
          setFieldState('error');
          setMicroStatus('Missing email', 'error');
          setMessage('Please enter your email.', 'error');
          return;
        }

        if (inputEmail.indexOf('@') < 1) {
          setFieldState('error');
          setMicroStatus('Invalid email format', 'error');
          setMessage('Please enter a valid email address.', 'error');
          return;
        }

        if (inputEmail !== loggedInEmail) {
          setFieldState('error');
          setMicroStatus('Account mismatch', 'error');
          setMessage('The email must match your logged-in customer account email.', 'error');
          return;
        }

        if (!isEmailAllowed(inputEmail, allowedRules)) {
          setFieldState('error');
          setMicroStatus('Not eligible', 'error');
          setMessage('This email is not eligible for beta access.', 'error');
          return;
        }

        if (!agreed) {
          setMicroStatus('Agreement required', 'error');
          setMessage('Please agree to the terms before submitting.', 'error');
          return;
        }

        if (!apiUrl) {
          setMicroStatus('Missing API URL', 'error');
          setMessage('Missing Vercel API URL setting.', 'error');
          return;
        }

        setFieldState('valid');
        setMicroStatus('Submitting application', 'info');
        setMessage('Submitting application...', 'info');
        setSubmittingState(true);

        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            customer_id: customerId,
            email: inputEmail,
            agreed: true
          })
        });

        const rawText = await response.text();
        let result = null;

        try {
          result = rawText ? JSON.parse(rawText) : null;
        } catch (e) {
          throw new Error(`Invalid server response: ${rawText || 'empty response'}`);
        }

        if (!response.ok) {
          throw new Error(result?.message || `Request failed with status ${response.status}`);
        }

        if (result && result.success) {
          setMicroStatus('Application submitted', 'valid');
          setMessage('Success. Your beta application has been submitted.', 'success');
          setSubmittingState(false);
          showSuccessPanel();
        } else {
          throw new Error(result?.message || 'Submission failed');
        }
      } catch (error) {
        setSubmittingState(false);
        setFieldState('error');
        setMicroStatus('Submission failed', 'error');
        setMessage(error.message || 'Something went wrong.', 'error');
      }
    });

    if (resetViewBtn) {
      resetViewBtn.addEventListener('click', function() {
        showFormPanel();
      });
    }
  })();
</script>

